<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ebonmarch / Valkyrie Weapon Master Tracker</title>
  <style>
    :root {
      --bg: #0b0b0d;
      --page-bg: #15121a;
      --panel: #242228;
      --panel-2: #343139;
      --panel-3: #47434d;
      --text: #f2f0ec;
      --muted: #c9c4bd;
      --silver: #e7e5df;
      --purple: #544268;
      --purple-2: #6d5883;
      --stone: #9c9c99;
      --black: #050505;
      --border: rgba(231, 229, 223, 0.34);
      --border-soft: rgba(231, 229, 223, 0.16);
      --shadow: rgba(0, 0, 0, 0.62);
      --good: #9fbf8f;
      --warn: #c6c1b8;
      --danger: #c97a7a;
      --radius: 16px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(84, 66, 104, 0.58), transparent 34%),
        radial-gradient(circle at bottom right, rgba(231, 229, 223, 0.12), transparent 30%),
        linear-gradient(135deg, var(--black) 0%, var(--page-bg) 48%, #2a2034 100%);
    }

    button,
    input,
    select {
      font: inherit;
    }

    .shell {
      width: min(1440px, calc(100% - 28px));
      margin: 0 auto;
      padding: 18px 0 42px;
    }

    .hero {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: center;
      padding: 18px 20px;
      margin-bottom: 16px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: linear-gradient(135deg, rgba(84, 66, 104, 0.95), rgba(36, 34, 40, 0.96));
      box-shadow: 0 12px 35px var(--shadow);
    }

    h1,
    h2,
    h3 {
      margin: 0;
    }

    h1 {
      font-size: clamp(1.8rem, 4vw, 3rem);
      color: var(--silver);
      line-height: 1;
    }

    .hero p {
      margin: 8px 0 0;
      color: var(--muted);
    }

    .status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgba(0,0,0,0.24);
      white-space: nowrap;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--warn);
      box-shadow: 0 0 10px var(--warn);
    }

    .dot.ready {
      background: var(--good);
      box-shadow: 0 0 10px var(--good);
    }

    .dot.error {
      background: var(--danger);
      box-shadow: 0 0 10px var(--danger);
    }

    .tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 16px;
    }

    .tab-btn,
    .btn {
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--silver);
      background: rgba(0,0,0,0.24);
      padding: 10px 14px;
      cursor: pointer;
    }

    .tab-btn.active,
    .btn.primary {
      background: rgba(84, 66, 104, 0.95);
      border-color: var(--silver);
    }

    .grid-main {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 16px;
      align-items: start;
    }

    .panel {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: rgba(36, 34, 40, 0.96);
      box-shadow: 0 10px 30px var(--shadow);
      overflow: hidden;
    }

    .panel-head {
      padding: 14px 16px;
      border-bottom: 1px solid var(--border-soft);
      background: linear-gradient(180deg, rgba(71, 67, 77, 0.98), rgba(36, 34, 40, 0.98));
    }

    .panel-head p {
      margin: 6px 0 0;
      color: var(--muted);
    }

    .panel-body {
      padding: 16px;
    }

    .recent-list {
      display: grid;
      gap: 12px;
    }

    .event-card {
      padding: 14px;
      border: 1px solid var(--border-soft);
      border-radius: 14px;
      background: rgba(0,0,0,0.18);
    }

    .event-card strong {
      display: block;
      color: var(--silver);
      font-size: 1.05rem;
    }

    .event-card span {
      display: block;
      color: var(--muted);
      margin-top: 4px;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 16px;
    }

    .field {
      display: grid;
      gap: 6px;
    }

    label {
      color: var(--silver);
      font-size: 0.84rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    input,
    select {
      width: 100%;
      min-height: 42px;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 9px 10px;
      color: var(--text);
      background: #141316;
      outline: none;
    }

    input:focus,
    select:focus {
      border-color: var(--silver);
      box-shadow: 0 0 0 3px rgba(231,229,223,0.12);
    }

    .brackets {
      display: grid;
      gap: 14px;
    }

    .bracket-card {
      border: 1px solid var(--border-soft);
      border-radius: 14px;
      overflow: hidden;
      background: rgba(0,0,0,0.16);
    }

    .bracket-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      padding: 12px 14px;
      border-bottom: 1px solid var(--border-soft);
      background: rgba(84,66,104,0.42);
    }

    .optional-tag,
    .required-tag {
      font-size: 0.76rem;
      padding: 4px 8px;
      border-radius: 999px;
      border: 1px solid var(--border-soft);
      color: var(--muted);
    }

    .required-tag {
      color: var(--silver);
      border-color: var(--border);
    }

    .placements {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
      padding: 14px;
    }

    .submit-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      margin-top: 16px;
    }

    .message {
      color: var(--muted);
    }

    .message.good {
      color: var(--good);
    }

    .message.error {
      color: var(--danger);
    }

    .leader-tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 12px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th,
    td {
      padding: 10px 8px;
      border-bottom: 1px solid rgba(231,229,223,0.11);
      text-align: left;
    }

    th {
      color: var(--silver);
      background: rgba(0,0,0,0.18);
      position: sticky;
      top: 0;
      z-index: 1;
    }

    td {
      color: var(--muted);
    }

    td:first-child,
    td:nth-child(3),
    td:nth-child(n+4) {
      text-align: center;
    }

    .leader-table-wrap {
      max-height: 520px;
      overflow: auto;
      border: 1px solid var(--border-soft);
      border-radius: 12px;
    }

    .view {
      display: none;
    }

    .view.active {
      display: block;
    }

    .note {
      color: var(--muted);
      font-size: 0.9rem;
    }

    @media (max-width: 980px) {
      .hero,
      .grid-main {
        grid-template-columns: 1fr;
      }

      .form-grid,
      .placements {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <main class="shell">
    <header class="hero">
      <div>
        <h1>Ebonmarch / Valkyrie Weapon Master</h1>
        <p>Track tournament results, rolling 12-month leaderboards, and recent events.</p>
      </div>
      <div class="status">
        <span id="statusDot" class="dot"></span>
        <span id="statusText">Loading...</span>
      </div>
    </header>

    <nav class="tabs">
      <button class="tab-btn active" data-view="home">Home</button>
      <button class="tab-btn" data-view="entry">Enter Tournament</button>
      <button class="tab-btn" data-view="leaders">Leaderboards</button>
    </nav>

    <section id="home" class="view active">
      <div class="grid-main">
        <div class="panel">
          <div class="panel-head">
            <h2>Most Recent 3 Tournaments</h2>
            <p>Events are stored for two years. Leaderboards only count the rolling last 12 months.</p>
          </div>
          <div class="panel-body">
            <div id="recentList" class="recent-list"></div>
          </div>
        </div>

        <div class="panel">
          <div class="panel-head">
            <h2>Quick Actions</h2>
            <p>Submit results or review current standings.</p>
          </div>
          <div class="panel-body" style="display:grid;gap:10px;">
            <button class="btn primary" data-jump="entry">Enter New Tournament</button>
            <button class="btn" data-jump="leaders" data-level="Ebonmarch">View Ebonmarch Leaderboard</button>
            <button class="btn" data-jump="leaders" data-level="Valkyrie">View Valkyrie Leaderboard</button>
          </div>
        </div>
      </div>
    </section>

    <section id="entry" class="view">
      <div class="panel">
        <div class="panel-head">
          <h2>Enter Tournament Results</h2>
          <p>Single Short, Sword and Board, and Florentine are required. Open and Great are optional.</p>
        </div>
        <div class="panel-body">
          <div class="form-grid">
            <div class="field">
              <label for="level">Type of Tournament</label>
              <select id="level">
                <option value="Ebonmarch">Duchy</option>
                <option value="Valkyrie">Valkyrie</option>
              </select>
            </div>
            <div class="field">
              <label for="eventDate">Event Date</label>
              <input id="eventDate" type="date" />
            </div>
            <div class="field">
              <label for="location">Location</label>
              <input id="location" type="text" placeholder="Park or event location" />
            </div>
          </div>

          <div id="brackets" class="brackets"></div>

          <div class="submit-row">
            <button id="submitBtn" class="btn primary" type="button">Submit Tournament</button>
            <div id="submitMessage" class="message"></div>
          </div>
        </div>
      </div>
    </section>

    <section id="leaders" class="view">
      <div class="panel">
        <div class="panel-head">
          <h2>Top 10 Leaderboard</h2>
          <p>Rolling 12-month standings. Ebonmarch and Valkyrie are separate.</p>
        </div>
        <div class="panel-body">
          <div class="leader-tabs">
            <button id="leaderEbonmarch" class="btn primary" type="button">Ebonmarch</button>
            <button id="leaderValkyrie" class="btn" type="button">Valkyrie</button>
          </div>
          <div class="leader-table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Rank</th>
                  <th>Player</th>
                  <th>Points</th>
                  <th>Events</th>
                  <th>1st</th>
                  <th>2nd</th>
                  <th>3rd</th>
                  <th>4th</th>
                  <th>5th</th>
                </tr>
              </thead>
              <tbody id="leaderBody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    "use strict";

    const API_URL = "https://script.google.com/macros/s/AKfycbw-KyzU9ZOZ5wNwvltar0HzihSBgHomOTI4nlrk_1f_mNZbZ9PezOHBrqpQmzyk5IeN/exec";

    const BRACKETS = [
      { key: "singleShort", name: "Single Short", required: true },
      { key: "swordBoard", name: "Sword & Board", required: true },
      { key: "flow", name: "Flow", required: true },
      { key: "open", name: "Open", required: false },
      { key: "greats", name: "Greats", required: false }
    ];

    const els = {
      statusDot: document.getElementById("statusDot"),
      statusText: document.getElementById("statusText"),
      recentList: document.getElementById("recentList"),
      brackets: document.getElementById("brackets"),
      submitBtn: document.getElementById("submitBtn"),
      submitMessage: document.getElementById("submitMessage"),
      leaderBody: document.getElementById("leaderBody"),
      leaderEbonmarch: document.getElementById("leaderEbonmarch"),
      leaderValkyrie: document.getElementById("leaderValkyrie")
    };

    let currentLeaderLevel = "Ebonmarch";

    init();

    function init() {
      buildBracketInputs();
      bindEvents();
      loadRecent();
      loadLeaderboard("Ebonmarch");
    }

    function bindEvents() {
      document.querySelectorAll(".tab-btn").forEach(btn => {
        btn.addEventListener("click", () => showView(btn.dataset.view));
      });

      document.querySelectorAll("[data-jump]").forEach(btn => {
        btn.addEventListener("click", () => {
          showView(btn.dataset.jump);
          if (btn.dataset.level) loadLeaderboard(btn.dataset.level);
        });
      });

      els.submitBtn.addEventListener("click", submitTournament);

      els.leaderEbonmarch.addEventListener("click", () => loadLeaderboard("Ebonmarch"));
      els.leaderValkyrie.addEventListener("click", () => loadLeaderboard("Valkyrie"));
    }

    function showView(id) {
      document.querySelectorAll(".view").forEach(view => view.classList.remove("active"));
      document.getElementById(id).classList.add("active");

      document.querySelectorAll(".tab-btn").forEach(btn => {
        btn.classList.toggle("active", btn.dataset.view === id);
      });
    }

    function buildBracketInputs() {
      els.brackets.innerHTML = BRACKETS.map(bracket => `
        <div class="bracket-card" data-bracket="${bracket.key}">
          <div class="bracket-head">
            <h3>${escapeHtml(bracket.name)}</h3>
            <span class="${bracket.required ? "required-tag" : "optional-tag"}">${bracket.required ? "Required" : "Optional"}</span>
          </div>
          <div class="placements">
            ${[1,2,3,4,5].map(place => `
              <div class="field">
                <label>${place}${suffix(place)} Place</label>
                <input type="text" data-place="${place}" placeholder="Player name" />
              </div>
            `).join("")}
          </div>
        </div>
      `).join("");
    }

    async function loadRecent() {
      setStatus("loading", "Loading recent...");

      try {
        const data = await jsonp(API_URL, { action: "recent" });
        renderRecent(data.events || []);
        setStatus("ready", "Ready");
      } catch (err) {
        setStatus("error", "Recent load failed");
        els.recentList.innerHTML = `<div class="note">Could not load recent tournaments.</div>`;
      }
    }

    function renderRecent(events) {
      if (!events.length) {
        els.recentList.innerHTML = `<div class="note">No tournaments submitted yet.</div>`;
        return;
      }

      els.recentList.innerHTML = events.slice(0, 3).map(event => `
        <div class="event-card">
          <strong>${escapeHtml(displayLevel(event.level))} · ${escapeHtml(event.location || "Unknown Location")}</strong>
          <span>${escapeHtml(event.eventDate || "No date listed")}</span>
          <span>${escapeHtml(String(event.bracketCount || 0))} brackets entered</span>
        </div>
      `).join("");
    }

    async function loadLeaderboard(level) {
      currentLeaderLevel = level;
      els.leaderEbonmarch.classList.toggle("primary", level === "Ebonmarch");
      els.leaderValkyrie.classList.toggle("primary", level === "Valkyrie");
      els.leaderBody.innerHTML = `<tr><td colspan="9">Loading...</td></tr>`;

      try {
        const data = await jsonp(API_URL, { action: "leaderboard", level });
        renderLeaderboard((data.players || []).slice(0, 10));
      } catch (err) {
        els.leaderBody.innerHTML = `<tr><td colspan="9">Could not load leaderboard.</td></tr>`;
      }
    }

    function renderLeaderboard(players) {
      if (!players.length) {
        els.leaderBody.innerHTML = `<tr><td colspan="9">No leaderboard results yet.</td></tr>`;
        return;
      }

      els.leaderBody.innerHTML = players.map(player => `
        <tr>
          <td>${escapeHtml(player.rank)}</td>
          <td>${escapeHtml(player.player)}</td>
          <td>${escapeHtml(player.totalPoints)}</td>
          <td>${escapeHtml(player.eventsEntered)}</td>
          <td>${escapeHtml(player.first)}</td>
          <td>${escapeHtml(player.second)}</td>
          <td>${escapeHtml(player.third)}</td>
          <td>${escapeHtml(player.fourth)}</td>
          <td>${escapeHtml(player.fifth)}</td>
        </tr>
      `).join("");
    }

    async function submitTournament() {
      clearMessage();

      const levelValue = document.getElementById("level").value;
      const level = levelValue === "Ebonmarch" ? "Ebonmarch" : "Valkyrie";
      const eventDate = document.getElementById("eventDate").value;
      const location = document.getElementById("location").value.trim();
      const brackets = collectBrackets();

      if (!eventDate) return showMessage("Event date is required.", "error");
      if (!location) return showMessage("Location is required.", "error");

      for (const bracket of BRACKETS.filter(b => b.required)) {
        const found = brackets.find(b => b.bracket === bracket.name);
        if (!found) return showMessage(`${bracket.name} is required.`, "error");
        if (!found.place1 || !found.place2 || !found.place3) {
          return showMessage(`${bracket.name} needs at least 1st, 2nd, and 3rd place.`, "error");
        }
      }

      const payload = {
        action: "submit",
        level,
        eventDate,
        location,
        brackets
      };

      els.submitBtn.disabled = true;
      showMessage("Submitting tournament...", "");

      try {
        await postJson(API_URL, payload);
        showMessage("Tournament submitted successfully.", "good");
        clearEntryForm();
        await loadRecent();
        await loadLeaderboard(level);
        showView("home");
      } catch (err) {
        showMessage("Submit failed. Apps Script may need POST permission or a redeploy.", "error");
      } finally {
        els.submitBtn.disabled = false;
      }
    }

    function collectBrackets() {
      return BRACKETS.map(bracket => {
        const card = document.querySelector(`[data-bracket="${bracket.key}"]`);
        const result = { bracket: bracket.name };

        card.querySelectorAll("input[data-place]").forEach(input => {
          result["place" + input.dataset.place] = input.value.trim();
        });

        const hasAny = [1,2,3,4,5].some(place => result["place" + place]);
        if (!hasAny && !bracket.required) return null;
        return result;
      }).filter(Boolean);
    }

    function clearEntryForm() {
      document.getElementById("eventDate").value = "";
      document.getElementById("location").value = "";
      els.brackets.querySelectorAll("input").forEach(input => input.value = "");
    }

    function jsonp(url, params = {}) {
      return new Promise((resolve, reject) => {
        const callbackName = "wmJsonp_" + Date.now() + "_" + Math.random().toString(36).slice(2);
        const query = new URLSearchParams({ ...params, callback: callbackName });
        const script = document.createElement("script");
        let timeoutId;

        window[callbackName] = data => {
          clearTimeout(timeoutId);
          delete window[callbackName];
          script.remove();
          resolve(data);
        };

        script.onerror = () => {
          clearTimeout(timeoutId);
          delete window[callbackName];
          script.remove();
          reject(new Error("JSONP failed"));
        };

        timeoutId = setTimeout(() => {
          delete window[callbackName];
          script.remove();
          reject(new Error("JSONP timed out"));
        }, 30000);

        script.src = url + "?" + query.toString();
        document.body.appendChild(script);
      });
    }

    async function postJson(url, payload) {
      const response = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: JSON.stringify(payload)
      });

      const data = await response.json();
      if (!data.ok) throw new Error(data.message || "Submit failed");
      return data;
    }

    function setStatus(type, text) {
      els.statusDot.className = "dot" + (type === "ready" ? " ready" : type === "error" ? " error" : "");
      els.statusText.textContent = text;
    }

    function showMessage(text, type) {
      els.submitMessage.textContent = text;
      els.submitMessage.className = "message" + (type ? " " + type : "");
    }

    function clearMessage() {
      showMessage("", "");
    }

    function displayLevel(level) {
      return level === "Ebonmarch" ? "Duchy" : level;
    }

    function suffix(n) {
      if (n === 1) return "st";
      if (n === 2) return "nd";
      if (n === 3) return "rd";
      return "th";
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }
  </script>
</body>
</html>
